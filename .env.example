# OAuth 42 — créer une app sur https://profile.intra.42.fr/oauth/applications
# Redirect URI à enregistrer : https://localhost:8443/api/auth/42/callback
#
# Poussé automatiquement dans Vault par vault_init au démarrage (make build).
# Laisser vide = OAuth42 reste désactivé (placeholder dans Vault), le reste
# de l'app fonctionne normalement.
OAUTH42_CLIENT_ID=
OAUTH42_CLIENT_SECRET=
