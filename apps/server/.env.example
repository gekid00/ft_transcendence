# Ce fichier ne sert PAS à `make build`/`make dev` (le serveur conteneurisé
# récupère tout via compose.yml + Vault, automatiquement). Il ne sert que si tu
# lances des commandes pnpm directement sur ta machine, hors conteneur :
#
#   pnpm --filter server db:generate   → besoin de : DATABASE_URL
#   pnpm --filter server db:migrate    → besoin de : DATABASE_URL
#   pnpm --filter server db:studio     → besoin de : DATABASE_URL
#   pnpm --filter server db:seed       → besoin de : DATABASE_URL
#   pnpm dev:server / pnpm start       → besoin de : DATABASE_URL, FRONTEND_URL,
#                                         OAUTH42_REDIRECT_URI, + soit VAULT_ADDR/
#                                         VAULT_TOKEN (récupère JWT_SECRET et
#                                         OAuth42 depuis Vault), soit JWT_SECRET/
#                                         OAUTH42_CLIENT_ID/OAUTH42_CLIENT_SECRET
#                                         en dur si Vault n'est pas joignable
#
# → Si on te demande juste une commande db:*, remplis seulement DATABASE_URL,
#   le reste peut rester vide.

# Toujours requis, pour toutes les commandes ci-dessus.
DATABASE_URL=postgres://user:password@localhost:5432/dbname

# Requis seulement pour : pnpm dev:server / pnpm start
FRONTEND_URL=http://localhost:4321

# Requis seulement pour : pnpm dev:server / pnpm start
# Différent du redirect URI du mode `make build` (https://localhost:8443/...) —
# pas un secret, donc jamais dans Vault : à adapter selon le port local réel.
OAUTH42_REDIRECT_URI=http://localhost:3000/api/auth/42/callback

# Optionnel, pour : pnpm dev:server / pnpm start
# Si rempli et que le stack `make build`/`make dev` tourne déjà, JWT_SECRET et
# les credentials OAuth42 ci-dessous sont auto-récupérés depuis Vault — pas
# besoin de les remplir. Token réel : podman exec vault_server cat /vault/file/root.token
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=

# Filet de secours pour : pnpm dev:server / pnpm start
# Uniquement si VAULT_ADDR/VAULT_TOKEN ci-dessus sont vides ou Vault injoignable.
JWT_SECRET=
OAUTH42_CLIENT_ID=
OAUTH42_CLIENT_SECRET=
